---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { getImage } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
import { site, nav } from "../config";
import heroImg from "../assets/hero-1.png";
import faviconSvg from "../assets/favicon.svg";

interface Props {
  title?: string;
  description?: string;
  pageType?: "WebPage" | "AboutPage" | "ContactPage" | "CollectionPage";
}
const { title, description, pageType = "WebPage" } = Astro.props;
const pageTitle = title ?? `${site.name} · ${site.tagline}`;
const pageDesc = description ?? site.description;
const canonical = new URL(Astro.url.pathname, site.url).href;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

// Imagen Open Graph (1200x630, JPG optimizado) generada en build a partir del hero.
const og = await getImage({
  src: heroImg,
  width: 1200,
  height: 630,
  format: "jpg",
  quality: 82,
});
const ogImageUrl = new URL(og.src, site.url).href;

// Favicons PNG (varias resoluciones) generadas a partir del SVG.
const fav16 = await getImage({ src: faviconSvg, width: 16, height: 16, format: "png" });
const fav32 = await getImage({ src: faviconSvg, width: 32, height: 32, format: "png" });
const fav96 = await getImage({ src: faviconSvg, width: 96, height: 96, format: "png" });
const fav192 = await getImage({ src: faviconSvg, width: 192, height: 192, format: "png" });
const fav512 = await getImage({ src: faviconSvg, width: 512, height: 512, format: "png" });
const appleIcon = await getImage({ src: faviconSvg, width: 180, height: 180, format: "png" });

// Etiqueta de página actual (para breadcrumb).
const currentNavItem = nav.find((n) => (n.href === "/" ? path === "/" : path.startsWith(n.href)));
const breadcrumbItems = [
  { name: "Inicio", url: `${site.url}/` },
  ...(path !== "/" && currentNavItem
    ? [{ name: currentNavItem.label, url: new URL(currentNavItem.href, site.url).href }]
    : []),
].map((b, i) => ({
  "@type": "ListItem",
  position: i + 1,
  name: b.name,
  item: b.url,
}));

// Datos estructurados (JSON-LD) consolidados en @graph.
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.url}#org`,
      name: site.legalName,
      alternateName: site.name,
      url: site.url,
      logo: new URL("/favicon.svg", site.url).href,
      email: site.email,
      sameAs: [site.instagram],
      areaServed: { "@type": "Country", name: "Chile" },
    },
    {
      "@type": "LegalService",
      "@id": `${site.url}#legal-service`,
      name: site.legalName,
      description: site.description,
      url: site.url,
      email: site.email,
      image: ogImageUrl,
      parentOrganization: { "@id": `${site.url}#org` },
      areaServed: { "@type": "Country", name: "Chile" },
      knowsAbout: [
        "Derecho educacional",
        "Asesoría jurídica educacional",
        "Rendición de subvenciones",
        "Convivencia escolar",
        "Ley de Inclusión",
        "Ley Karin",
        "Superintendencia de Educación",
        "Ministerio de Educación",
        "Responsabilidad penal adolescente",
        "Tribunales de Familia",
      ],
      availableLanguage: "es-CL",
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}#website`,
      name: site.name,
      url: site.url,
      inLanguage: "es-CL",
      description: site.description,
      publisher: { "@id": `${site.url}#org` },
    },
    {
      "@type": pageType,
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: pageTitle,
      description: pageDesc,
      inLanguage: "es-CL",
      isPartOf: { "@id": `${site.url}#website` },
      primaryImageOfPage: ogImageUrl,
      breadcrumb: { "@id": `${canonical}#breadcrumb` },
      about: { "@id": `${site.url}#org` },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      itemListElement: breadcrumbItems,
    },
  ],
};

// Verificación de Google Search Console.
const gscVerification = "nqskf-p9zC8hi03tYqHvhs7HCN1Oz3GVvHFFrzLO9l0";
---
<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="author" content={site.legalName} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href={fav16.src} />
    <link rel="icon" type="image/png" sizes="32x32" href={fav32.src} />
    <link rel="icon" type="image/png" sizes="96x96" href={fav96.src} />
    <link rel="icon" type="image/png" sizes="192x192" href={fav192.src} />
    <link rel="icon" type="image/png" sizes="512x512" href={fav512.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleIcon.src} />
    <link rel="shortcut icon" href={fav32.src} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="alternate" hreflang="es-CL" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <meta name="theme-color" content="#5b2a86" />

    <meta name="google-site-verification" content={gscVerification} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.legalName} — ${site.tagline}`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${site.legalName} — ${site.tagline}`} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-brand-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <FloatingCTA />

    <script>
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>(".reveal:not(.is-visible)");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }

      function initCounters() {
        const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
        if (!counters.length) return;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const run = (el: HTMLElement) => {
          const target = Number(el.dataset.counter || "0");
          if (reduce) { el.textContent = String(target); return; }
          const dur = 1400;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        const io = new IntersectionObserver((entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              run(entry.target as HTMLElement);
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        counters.forEach((el) => io.observe(el));
      }

      function initMenu() {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        if (!toggle || !menu) return;
        const open = (state: boolean) => {
          menu.classList.toggle("hidden", !state);
          toggle.setAttribute("aria-expanded", String(state));
          toggle.setAttribute("aria-label", state ? "Cerrar menú" : "Abrir menú");
          toggle.querySelector(".menu-open")?.classList.toggle("hidden", state);
          toggle.querySelector(".menu-close")?.classList.toggle("hidden", !state);
        };
        toggle.addEventListener("click", () =>
          open(menu.classList.contains("hidden"))
        );
        menu.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => open(false))
        );
      }

      let scrollBound = false;
      function onScroll() {
        const bar = document.getElementById("header-bar");
        if (bar) bar.classList.toggle("scrolled", window.scrollY > 8);
      }
      function initHeader() {
        onScroll();
        if (!scrollBound) {
          window.addEventListener("scroll", onScroll, { passive: true });
          scrollBound = true;
        }
      }

      function init() {
        initReveal();
        initCounters();
        initMenu();
        initHeader();
      }

      document.addEventListener("astro:page-load", init);
    </script>

    <style is:global>
      #header-bar.scrolled {
        background-color: color-mix(in srgb, var(--color-cream) 80%, transparent);
        border-color: var(--color-line);
        backdrop-filter: saturate(180%) blur(12px);
        box-shadow: 0 8px 30px -12px rgba(40, 18, 63, 0.18);
      }
    </style>
  </body>
</html>
