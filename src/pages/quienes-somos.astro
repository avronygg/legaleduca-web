---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Figure from "../components/Figure.astro";
import Icon from "../components/Icon.astro";
import { values, aboutText } from "../config";
import quienesImg from "../assets/quienessomos.png";

const focusAreas = [
  "Revisión de reglamentos internos",
  "Aplicación de la normativa vigente",
  "Ley de Inclusión",
  "Convivencia escolar",
  "Rendición de subvenciones",
  "Representación ante organismos públicos",
];
---
<Layout
  title="Quiénes somos en derecho educacional | LegalEduca"
  description="Conoce a LegalEduca: abogadas expertas en derecho educacional y auditores en rendición de subvenciones que asesoran a establecimientos educacionales en todo Chile."
>
  <PageHero
    eyebrow="Quiénes somos"
    title="Abogadas expertas en <span class='text-gradient'>derecho educacional</span>"
    subtitle="Un equipo especializado que conoce la normativa educacional desde adentro y la pone al servicio de tu establecimiento."
  />

  <!-- Intro real -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
      <div class="reveal">
        <Figure
          src={quienesImg}
          ratio="4/3"
          widths={[400, 600, 800, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          alt="Equipo de abogadas de Legal Educa en su oficina"
        />
      </div>
      <div class="reveal reveal-d1">
        <span class="mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-brand-600">
          <span class="brand-gradient h-1.5 w-1.5 rounded-full"></span>
          Nuestro equipo
        </span>
        <h2 class="text-3xl leading-[1.12] sm:text-4xl">
          Especialistas en derecho educacional
        </h2>
        <p class="mt-5 text-base leading-relaxed text-ink-soft sm:text-lg">
          {aboutText}
        </p>
        <ul class="mt-7 grid gap-3 sm:grid-cols-2">
          {
            focusAreas.map((area) => (
              <li class="flex items-start gap-2.5 text-sm text-ink">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-600">
                  <Icon name="check" class="h-3 w-3" />
                </span>
                {area}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Misión / Visión -->
  <section class="border-y border-line bg-cream-alt py-20 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div class="reveal rounded-3xl border border-line bg-white p-8 sm:p-10">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
          <Icon name="spark" class="h-6 w-6" />
        </span>
        <h2 class="mt-5 text-2xl sm:text-3xl">Misión</h2>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">
          Entregar asesoría legal de excelencia a los establecimientos
          educacionales, garantizando el cumplimiento de la normativa y
          previniendo riesgos, observaciones y multas.
        </p>
      </div>
      <div class="reveal reveal-d1 rounded-3xl border border-line bg-brand-900 p-8 text-white sm:p-10">
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 text-white">
          <Icon name="eye" class="h-6 w-6" />
        </span>
        <h2 class="mt-5 text-2xl text-white sm:text-3xl">Visión</h2>
        <p class="mt-3 text-base leading-relaxed text-brand-100/80">
          Ser un referente en derecho educacional en Chile, reconocidos por la
          experiencia, la cercanía y el impacto positivo en las comunidades
          educativas que acompañamos.
        </p>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Nuestros valores"
        title="Lo que guía cada decisión"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((v, i) => (
            <div class:list={["reveal rounded-2xl border border-line bg-white p-7", `reveal-d${i % 4}`]}>
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                <Icon name={v.icon} class="h-5 w-5" />
              </span>
              <h3 class="mt-4 text-lg text-ink">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-line bg-cream-alt py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="reveal text-3xl sm:text-4xl">Trabajemos juntos</h2>
      <p class="reveal reveal-d1 mx-auto mt-4 max-w-xl text-ink-soft">
        Estamos listos para escuchar tu caso y orientarte con claridad.
      </p>
      <div class="reveal reveal-d2 mt-8">
        <Button href="/contacto" size="lg" icon="arrow">Contáctanos</Button>
      </div>
    </div>
  </section>
</Layout>
