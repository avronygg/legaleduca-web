---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { site, services } from "../config";

const configured = site.web3formsKey !== "TU_ACCESS_KEY_DE_WEB3FORMS";

const contactItems = [
  { icon: "mail", label: "Correo", value: site.email, href: `mailto:${site.email}` },
  site.phone && { icon: "phone", label: "Teléfono", value: site.phone, href: `tel:${site.phoneHref}` },
  site.address && { icon: "location", label: "Oficina", value: site.address, href: undefined },
].filter(Boolean) as { icon: string; label: string; value: string; href?: string }[];

const inputCls =
  "w-full rounded-xl border border-line bg-white px-4 py-3 text-sm text-ink placeholder:text-ink-soft/60 transition-colors focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-200";
const labelCls = "mb-1.5 block text-sm font-medium text-ink";
---
<Layout
  title="Contacto | Asesoría legal para colegios | LegalEduca"
  description="Contáctanos y solicita tu asesoría jurídica educacional. Te orientamos en cumplimiento normativo, rendición de subvenciones y convivencia escolar."
>
  <PageHero
    eyebrow="Contacto"
    title="Solicita tu <span class='text-gradient'>asesoría legal educacional</span>"
    subtitle="Completa el formulario con los detalles de tu consulta y te responderemos a la brevedad."
  />

  <section class="py-20 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-5 lg:gap-16 lg:px-8">
      <!-- Datos de contacto -->
      <div class="reveal lg:col-span-2">
        <h2 class="text-2xl sm:text-3xl">Información de contacto</h2>
        <p class="mt-3 text-ink-soft">
          Estamos para ayudarte. Escríbenos y te responderemos a la brevedad.
        </p>

        <div class="mt-8 flex items-center gap-4 rounded-2xl border border-line bg-cream-alt p-5">
          <span class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-full brand-gradient text-lg font-semibold text-white">
            PM
          </span>
          <div>
            <p class="font-serif text-lg font-semibold text-ink">{site.contactPerson}</p>
            <p class="text-sm text-ink-soft">{site.contactRole}</p>
          </div>
        </div>

        <ul class="mt-4 space-y-4">
          {
            contactItems.map((item) => {
              const Inner = item.href ? "a" : "div";
              return (
                <li>
                  <Inner
                    href={item.href}
                    target={item.href?.startsWith("http") ? "_blank" : undefined}
                    rel={item.href?.startsWith("http") ? "noopener noreferrer" : undefined}
                    class:list={[
                      "flex items-start gap-4 rounded-2xl border border-line bg-white p-4 transition-all",
                      item.href && "hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md",
                    ]}
                  >
                    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                      <Icon name={item.icon} class="h-5 w-5" />
                    </span>
                    <span>
                      <span class="block text-xs font-semibold uppercase tracking-wider text-brand-500">
                        {item.label}
                      </span>
                      <span class="mt-0.5 block break-words text-sm text-ink">{item.value}</span>
                    </span>
                  </Inner>
                </li>
              );
            })
          }
        </ul>

        <div class="mt-6 flex items-center gap-3 rounded-2xl border border-line bg-cream-alt p-4 text-sm text-ink-soft">
          <Icon name="clock" class="h-5 w-5 shrink-0 text-brand-500" />
          Lunes a viernes, 9:00 a 18:00 hrs.
        </div>
      </div>

      <!-- Formulario -->
      <div class="reveal reveal-d1 lg:col-span-3">
        <div class="rounded-3xl border border-line bg-white p-6 sm:p-8 lg:p-10">
          <form id="contact-form" data-configured={String(configured)} novalidate>
            <input type="hidden" name="access_key" value={site.web3formsKey} />
            <input type="hidden" name="subject" value="Nuevo contacto desde el sitio web de Legal Educa" />
            <input type="hidden" name="from_name" value="Sitio web Legal Educa" />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class={labelCls} for="name">Nombre completo *</label>
                <input class={inputCls} type="text" id="name" name="name" required placeholder="Tu nombre" autocomplete="name" />
              </div>
              <div>
                <label class={labelCls} for="email">Correo electrónico *</label>
                <input class={inputCls} type="email" id="email" name="email" required placeholder="tu@correo.cl" autocomplete="email" />
              </div>
              <div>
                <label class={labelCls} for="phone">Teléfono</label>
                <input class={inputCls} type="tel" id="phone" name="phone" placeholder="+56 9 ..." autocomplete="tel" />
              </div>
              <div>
                <label class={labelCls} for="topic">Tema de consulta</label>
                <select class={inputCls} id="topic" name="topic">
                  <option value="">Selecciona una opción</option>
                  {services.map((s) => <option value={s.title}>{s.title}</option>)}
                  <option value="Otro">Otro</option>
                </select>
              </div>
            </div>

            <div class="mt-5">
              <label class={labelCls} for="message">Mensaje *</label>
              <textarea class={`${inputCls} resize-y`} id="message" name="message" rows="5" required placeholder="Cuéntanos brevemente tu caso..."></textarea>
            </div>

            <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-xs text-ink-soft">
                Al enviar, aceptas que te contactemos para responder tu consulta.
              </p>
              <button
                type="submit"
                id="submit-btn"
                class="group inline-flex items-center justify-center gap-2 rounded-full brand-gradient px-7 py-3.5 text-base font-medium text-white shadow-lg shadow-flame/20 transition-all duration-200 hover:shadow-xl hover:brightness-[1.05] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 disabled:opacity-60"
              >
                <span id="btn-text">Enviar mensaje</span>
                <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </button>
            </div>

            <!-- Mensajes de estado -->
            <div
              id="form-status"
              role="status"
              aria-live="polite"
              class="mt-5 hidden rounded-xl px-4 py-3 text-sm"
            >
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initContactForm() {
      const form = document.getElementById("contact-form") as HTMLFormElement | null;
      if (!form) return;
      const btn = document.getElementById("submit-btn") as HTMLButtonElement;
      const btnText = document.getElementById("btn-text") as HTMLSpanElement;
      const status = document.getElementById("form-status") as HTMLDivElement;
      const configured = form.dataset.configured === "true";

      const show = (msg: string, ok: boolean) => {
        status.textContent = msg;
        status.classList.remove("hidden");
        status.classList.toggle("bg-green-50", ok);
        status.classList.toggle("text-green-800", ok);
        status.classList.toggle("ring-1", true);
        status.classList.toggle("ring-green-200", ok);
        status.classList.toggle("bg-red-50", !ok);
        status.classList.toggle("text-red-800", !ok);
        status.classList.toggle("ring-red-200", !ok);
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        if (!configured) {
          show(
            "El formulario aún no está conectado. Configura tu Access Key de Web3Forms en src/config.ts para recibir los mensajes.",
            false
          );
          return;
        }

        btn.disabled = true;
        const original = btnText.textContent;
        btnText.textContent = "Enviando...";
        status.classList.add("hidden");

        try {
          const data = Object.fromEntries(new FormData(form));
          const res = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: { "Content-Type": "application/json", Accept: "application/json" },
            body: JSON.stringify(data),
          });
          const result = await res.json();
          if (result.success) {
            form.reset();
            show("¡Gracias! Tu mensaje fue enviado. Te responderemos pronto.", true);
          } else {
            show("Hubo un problema al enviar. Inténtalo nuevamente o escríbenos directamente a nuestro correo.", false);
          }
        } catch {
          show("No se pudo enviar. Revisa tu conexión e intenta otra vez.", false);
        } finally {
          btn.disabled = false;
          btnText.textContent = original;
        }
      });
    }

    document.addEventListener("astro:page-load", initContactForm);
  </script>
</Layout>
