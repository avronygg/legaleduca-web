---
import Icon from "./Icon.astro";
import type { Service } from "../config";

interface Props {
  service: Service;
  index?: number;
  href?: string;
}
const { service, index = 0, href } = Astro.props;
const delay = ["", "reveal-d1", "reveal-d2", "reveal-d3"][index % 4];
const Tag = href ? "a" : "div";
---
<Tag
  href={href}
  class:list={[
    "reveal group relative flex flex-col rounded-2xl border border-line bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-brand-200 hover:shadow-xl hover:shadow-brand-900/5",
    delay,
    href && "cursor-pointer",
  ]}
>
  <span
    class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 transition-colors duration-300 group-hover:bg-brand-100"
  >
    <Icon name={service.icon} class="h-6 w-6" />
  </span>

  <h3 class="mt-5 text-xl text-ink">{service.title}</h3>
  <p class="mt-1 text-xs font-medium uppercase tracking-wider text-brand-500">
    {service.audience}
  </p>
  <p class="mt-3 text-sm leading-relaxed text-ink-soft">{service.summary}</p>

  {
    href && (
      <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-brand-700">
        Conocer más
        <Icon name="arrow" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" />
      </span>
    )
  }
</Tag>
